<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kino Date?</title>

  <style>
    body {
      margin: 0;
      height: 100vh;
      font-family: Arial, sans-serif;
      background: linear-gradient(135deg, #ff9a9e, #fad0c4);
      display: flex;
      justify-content: center;
      align-items: center;
      text-align: center;
      overflow: hidden;
    }

    .box {
      background: white;
      padding: 35px;
      border-radius: 25px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
      max-width: 350px;
    }

    h1 {
      color: #ff4f81;
      font-size: 28px;
    }

    p {
      font-size: 18px;
      color: #444;
    }

    .buttons {
      margin-top: 25px;
      position: relative;
      height: 80px;
    }

    button {
      padding: 14px 24px;
      border: none;
      border-radius: 30px;
      font-size: 18px;
      cursor: pointer;
      transition: 0.3s;
    }

    #yes {
      background-color: #ff4f81;
      color: white;
    }

    #no {
      background-color: #ddd;
      color: #333;
      position: absolute;
      left: 190px;
    }

    .heart {
      font-size: 50px;
      animation: pulse 1s infinite;
    }

    @keyframes pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.2); }
      100% { transform: scale(1); }
    }
  </style>
</head>

<body>
  <div class="box">
    <div class="heart">❤️</div>
    <h1>Willst du heute mit mir ins Kino gehen?</h1>
    <p>Ich würde mich sehr freuen, den Abend mit dir zu verbringen 🍿🎬</p>

    <div class="buttons">
      <button id="yes" onclick="sayYes()">Ja, natürlich 💕</button>
      <button id="no" onmouseover="moveNo()">Nein</button>
    </div>
  </div>

  <script>
    function sayYes() {
      document.body.innerHTML = `
        <div style="
          height:100vh;
          display:flex;
          justify-content:center;
          align-items:center;
          text-align:center;
          font-family:Arial;
          background:linear-gradient(135deg,#ff9a9e,#fad0c4);
        ">
          <div style="
            background:white;
            padding:35px;
            border-radius:25px;
            max-width:350px;
            box-shadow:0 10px 30px rgba(0,0,0,0.2);
          ">
            <h1 style="color:#ff4f81;">Jaaaa ❤️</h1>
            <p style="font-size:20px;">Dann ist es ein Date 🍿🎬</p>
            <p style="font-size:18px;">Ich freue mich auf heute Abend mit dir.</p>
          </div>
        </div>
      `;
    }

    function moveNo() {
      const noButton = document.getElementById("no");
      const x = Math.random() * 180;
      const y = Math.random() * 50;

      noButton.style.left = x + "px";
      noButton.style.top = y + "px";
    }
  </script>
</body>
</html>